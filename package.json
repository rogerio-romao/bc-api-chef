{
    "name": "bc-api-chef",
    "version": "0.0.3",
    "description": "Node application to serve the BigCommerce API",
    "license": "ISC",
    "author": "Rogerio Romao",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --target=es2022 --minify --sourcemap",
        "check": "pnpm run fmt:check && pnpm run lint && pnpm run test:ci && pnpm run test:integration && pnpm run typecheck && pnpm run build",
        "dev": "run-p dev:*",
        "dev:esbuild": "pnpm run build --watch",
        "dev:node": "node --env-file=.env --watch dist/index.js",
        "dev:tsc": "tsc --watch --preserveWatchOutput --noEmit",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "prepare": "husky",
        "scratch": "node --env-file=.env src/scratchpad.ts",
        "start": "node --env-file=.env dist/index.js",
        "test": "vitest --project unit",
        "test:ci": "vitest --run --project unit",
        "test:integration": "vitest --run --project integration",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "tchef": "^0.4.14"
    },
    "devDependencies": {
        "@types/node": "^20.12.11",
        "esbuild": "^0.25.0",
        "husky": "^9.1.7",
        "npm-run-all2": "^6.1.2",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.58.0",
        "typescript": "^5.3.3",
        "vitest": "^3.0.0"
    },
    "pnpm": {
        "overrides": {
            "undici-types": "~5.26.4",
            "semver@6": "6.3.0",
            "semver@5": "5.7.1",
            "vite": "5.2.11"
        },
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}
