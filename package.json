{
    "name": "bc-api-chef",
    "version": "0.0.2",
    "description": "Node application to serve the BigCommerce API",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --target=es2022 --minify --sourcemap",
        "test": "vitest",
        "test:ci": "vitest --run",
        "test:integration": "vitest --run --config vitest.integration.config.ts",
        "start": "node --env-file=.env dist/index.js",
        "dev:tsc": "tsc --watch --preserveWatchOutput --noEmit",
        "dev:node": "node --env-file=.env --watch dist/index.js",
        "dev:esbuild": "pnpm run build --watch",
        "dev": "run-p dev:*",
        "typecheck": "tsc --noEmit"
    },
    "author": "Rogerio Romao",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^20.12.11",
        "esbuild": "^0.25.0",
        "eslint": "^9.0.0",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-promise": "^6.1.1",
        "eslint-plugin-sonarjs": "^1.0.3",
        "eslint-plugin-unicorn": "^52.0.0",
        "globals": "^15.2.0",
        "npm-run-all2": "^6.1.2",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.58.0",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "consola": "^3.2.3",
        "tchef": "^0.4.6",
        "valibot": "^0.30.0"
    },
    "pnpm": {
        "overrides": {
            "undici-types": "~5.26.4",
            "semver@6": "6.3.0",
            "semver@5": "5.7.1",
            "vite": "5.2.11"
        },
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}
